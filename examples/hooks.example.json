{
  "description": "Example agent hooks for a repository that uses CodeRail. Replace <path-to-coderail> with the local CodeRail package path.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .coderail/coderail.py hook --stage prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .coderail/coderail.py hook --stage pre-edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .coderail/coderail.py hook --stage stop"
          }
        ]
      }
    ]
  }
}
