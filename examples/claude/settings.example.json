{
  "permissions": {
    "deny": [
      "Write(docs/TRACELOG.jsonl) unless appending via trace_event.py"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .coderail/coderail.py hook --stage prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .coderail/coderail.py hook --stage pre-edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .coderail/coderail.py hook --stage stop"
          }
        ]
      }
    ]
  }
}
